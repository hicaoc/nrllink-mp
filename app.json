{
  "pages": [
    "pages/login/login",
    "pages/register/register",
    "pages/settings/settings",
    "pages/config/config",
    "pages/ble-config/ble-config",
    "pages/lan-devices/lan-devices",
    "pages/lan-device/lan-device",
    "pages/my-devices/my-devices",
    "pages/my-device-at/my-device-at",
    "pages/aprs/aprs",
    "pages/voice/voice",
    "pages/group-detail/group-detail",
    "pages/device-settings/device-settings",
    "pages/privacy-policy/privacy-policy",
    "pages/user-agreement/user-agreement",
    "pages/webview/webview"
  ],
  "window": {
    "navigationBarTitleText": "NRL互联1.8.1"
  },
  "tabBar": {
    "list": [
      {
        "pagePath": "pages/voice/voice",
        "text": "通话",
        "iconPath": "images/voice.png",
        "selectedIconPath": "images/voice-active.png"
      },
      {
        "pagePath": "pages/aprs/aprs",
        "text": "APRS",
        "iconPath": "images/aprs.png",
        "selectedIconPath": "images/aprs-active.png"
      },
      {
        "pagePath": "pages/settings/settings",
        "text": "设置",
        "iconPath": "images/config.png",
        "selectedIconPath": "images/config-active.png"
      },
      {
        "pagePath": "pages/my-devices/my-devices",
        "text": "我的",
        "iconPath": "images/my.png",
        "selectedIconPath": "images/my-active.png"
      }
    ]
  },
  "networkTimeout": {
    "request": 10000,
    "connectSocket": 10000,
    "uploadFile": 10000,
    "downloadFile": 10000
  },
  "requiredBackgroundModes": [
    "audio",
    "location"
  ],
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于语音通信和APRS分享"
    }
  },
  "requiredPrivateInfos": [
    "getLocation",
    "onLocationChange",
    "startLocationUpdateBackground"
  ],
  "useExtendedLib": {
    "weui": true
  }
}
