.page-container {
  padding: 16px;
}

.nav-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.nav-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  padding: 18px 16px;
}

.nav-item:active {
  background: #f2f4f7;
}

.nav-icon {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex: none;
  margin-right: 14px;
}

.icon-ble { background: #e8f3ff; }
.icon-lan { background: #f0e8ff; }
.icon-group { background: #e9f9ef; }
.icon-exit { background: #fdeaea; }

.nav-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.nav-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f2329;
}

.nav-desc {
  font-size: 12px;
  color: #999;
}

.nav-arrow {
  font-size: 22px;
  color: #c0c4cc;
  flex: none;
  margin-left: 8px;
}

.nav-danger .nav-title { color: #e54d42; }
